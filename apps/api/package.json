{
  "name": "@gam/api",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "migrate": "node -r ts-node/register src/db/migrate.ts",
    "test": "DB_NAME=gam_test vitest run",
    "test:watch": "DB_NAME=gam_test vitest",
    "seed": "node -r ts-node/register src/db/seed.ts",
    "schema:diff": "node -r ts-node/register scripts/diff-schema.ts",
    "db:dump-schema": "bash scripts/dump-schema.sh",
    "verify:webhooks": "node -r ts-node/register scripts/verify-stripe-webhooks.ts"
  },
  "dependencies": {
    "@gam/shared": "*",
    "@napi-rs/canvas": "^0.1.80",
    "@sentry/node": "^8.55.2",
    "@types/multer": "^2.1.0",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "otplib": "^12.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.11.3",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.4",
    "stripe": "^14.25.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  }
}
