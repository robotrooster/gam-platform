# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gam
DB_USER=postgres
DB_PASSWORD=your_password

# Auth
JWT_SECRET=change_this_to_a_long_random_string_min_64_chars

# Email (Resend) — S288: two senders, routed per email kind.
#   noreply: system emails the user shouldn't reply to (password
#     reset, verification, late-payment notices, signing reminders,
#     auto-voids, allocation/payout receipts, generic notifications).
#   support: human-facing emails where a reply is welcome (invitations,
#     adverse-action notices that legally invite the recipient to
#     contact the data furnisher).
# Each domain needs SPF + DKIM + DMARC records added in your DNS
# (Resend generates the exact records when you add the domain in
# the Resend dashboard).
RESEND_API_KEY=re_...
EMAIL_FROM_NOREPLY="GAM <noreply@goldassetmanagement.com>"
EMAIL_FROM_SUPPORT="GAM Support <support@goldassetmanagement.com>"
# Back-compat fallback. Old EMAIL_FROM still works — both senders fall
# back to this value if their specific env var isn't set, then to the
# Resend dev playground sender.
# EMAIL_FROM="GAM Platform <onboarding@resend.dev>"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe publishable key — exposed to the browser bundle, intentionally public.
# Set in apps/tenant/.env (and any other portal that mounts Stripe Elements).
# When unset, the bg check intake page falls back to a mock-pay button that
# uses pi_intake_mock_* IDs accepted by the backend in non-production only.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Disbursement firing rail. 'stub' (default) generates synthetic payout IDs
# and advances disbursements to 'processing' without firing real ACH —
# used in dev until GAM's bank ACH origination provider is wired.
# 'bank_ach' will originate via the chosen provider (Increase / Column /
# Modern Treasury / Mercury / direct bank API / NACHA file). Currently
# throws — Item 16 batch 2 wires the real call once the provider is picked.
# Architecture note: GAM is sole merchant of record. Stripe is inbound only
# (tenant debits, IC+ priced); outbound ACH credits go via GAM's bank rail.
DISBURSEMENT_RAIL=stub

# App URLs (server-side)
LANDLORD_APP_URL=http://localhost:3001
TENANT_APP_URL=http://localhost:3002
ADMIN_APP_URL=http://localhost:3003
MARKETING_URL=http://localhost:3004
PM_COMPANY_APP_URL=http://localhost:3011

# Browser-bundle App URLs (Vite-prefixed; only set in apps/<portal>/.env if
# the portal needs to link cross-portal). Defaults to localhost values
# when unset — fine for dev, set explicitly for staging/prod.
# VITE_LANDLORD_APP_URL=https://app.gam.example.com
# VITE_TENANT_APP_URL=https://tenant.gam.example.com
# VITE_PM_COMPANY_APP_URL=https://pm.gam.example.com

# API
PORT=4000

# Sentry (apps/api). Leave unset in dev — `apps/api/src/instrument.ts`
# skips init entirely when SENTRY_DSN is empty, so every Sentry call
# becomes a no-op (no captures, no network). Set the DSN in
# staging/prod env to enable error tracking.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_RELEASE=  # populated by the deploy pipeline, e.g. git sha

# Sentry — frontend apps. VITE_-prefixed so Vite injects into the
# browser bundle at build time. Set per-portal in each apps/<portal>/.env
# OR set one shared DSN here and reuse — same project in Sentry can
# accept events from multiple sources, distinguishable by `environment`
# and the auto-attached `release`. Each frontend's `src/lib/sentry.ts`
# no-ops when this is unset, matching the api-side posture.
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<frontend-project>
# VITE_SENTRY_RELEASE=  # set by deploy pipeline, e.g. git sha

# Password reset (S279). Base URL emailed to users requesting a
# password reset. Token is appended as `?token=...`. Defaults to the
# tenant portal in dev; set per-environment for staging/prod.
# Underlying form just consumes the token, so any portal works —
# pick the one your users expect to land on (tenant portal usually).
# RESET_PASSWORD_URL=https://tenant.gam.example.com/reset-password

# Email verification (S281). Base URL emailed at registration to
# confirm ownership of the address. Same shape as RESET_PASSWORD_URL.
# Defaults to tenant portal in dev.
# VERIFY_EMAIL_URL=https://tenant.gam.example.com/verify-email

# Agent engine (customer-service AI agents). Self-hosted, OpenAI-
# compatible LLM endpoint — NO third-party AI API, no per-token cost,
# all tenant data stays on GAM-controlled hardware. Both URL and model
# are env-driven so dev->prod and machine->machine is a config change,
# not an engine rebuild.
#   Dev: Hermes-4-14B (4-bit) via MLX on localhost.
#   Prod: larger Hermes behind the same endpoint, swapped here.
LLM_ENDPOINT=http://localhost:8080/v1
LLM_MODEL=mlx-community/Hermes-4-14B-4bit
# Per-request timeout (ms). Optional; defaults to 60000. A local model
# on modest hardware can be slow to first token.
# LLM_TIMEOUT_MS=60000
# Max tokens generated per call. Optional; defaults to 1024. Needs to
# leave room for a tool call to follow any preamble text.
# LLM_MAX_TOKENS=1024

# Agent engine — embeddings (RAG knowledge retrieval). A SECOND self-
# hosted, OpenAI-compatible endpoint, separate from the chat model.
# Turns text into vectors for the knowledge store. Dev runs
# bge-large-en-v1.5 (1024-dim) via llama.cpp on a second port. The
# 1024 dimension is locked into the DB schema (vector(1024)) and the
# EMBEDDING_DIM constant — changing the model means a new migration +
# re-embedding every chunk.
#   Start the dev server with: ./scripts/start-embeddings.sh
EMBEDDINGS_ENDPOINT=http://localhost:8081/v1
EMBEDDINGS_MODEL=bge-large-en-v1.5

# Scale (prod): to spread load across a fleet of model workers, set the
# PLURAL list vars instead — comma-separated base URLs. The app routes by
# least-in-flight and fails over across them with zero redeploy. The
# singular vars above stay as a one-worker fallback (dev). Dev team adds
# workers by appending URLs here; no code change.
#   LLM_ENDPOINTS=http://gpu-1:8080/v1,http://gpu-2:8080/v1,http://gpu-3:8080/v1
#   EMBEDDINGS_ENDPOINTS=http://emb-1:8081/v1,http://emb-2:8081/v1

# Scale — turn-admission gate (graceful degradation under load). Admit up to
# AGENT_MAX_CONCURRENCY agent turns at once; queue up to AGENT_QUEUE_MAX more
# for AGENT_QUEUE_WAIT_MS; shed the rest with a "high volume, retry" reply.
# Tune MAX to (worker count × safe concurrent streams per worker).
#   AGENT_MAX_CONCURRENCY=16
#   AGENT_QUEUE_MAX=200
#   AGENT_QUEUE_WAIT_MS=10000
# Scale — caches. Embedding cache is ON by default (query embeddings are a
# pure function of the locked model). The FAQ answer cache is OFF until a TTL
# is set — it serves repeated, non-personalized grounded answers with NO model
# call; enabling it is a quality/staleness call (stale up to its TTL).
#   AGENT_EMBED_CACHE_MAX=5000
#   AGENT_EMBED_CACHE_TTL_MS=86400000
#   AGENT_ANSWER_CACHE_TTL_MS=0      # >0 enables the answer cache
#   AGENT_ANSWER_CACHE_MAX=2000
# Per-request timeout (ms). Optional; defaults to 30000.
# EMBEDDINGS_TIMEOUT_MS=30000

# Checkr — background-check provider (S420 implementation, S451 live wire).
# GAM platform key — ONE key for the whole platform. Per-check costs land
# on GAM's Checkr bill; GAM marks up + bills the landlord/tenant downstream
# (see project_checkr_billing_model memory). Do NOT use per-landlord keys.
#
# To enable Checkr on a specific landlord (instead of the default 'mock'):
#   UPDATE landlords SET background_provider='checkr' WHERE id='<llid>';
#
# Staging URL: https://api.checkr-staging.com/v1   (use during smoke testing)
# Production URL: https://api.checkr.com/v1        (default if BASE_URL omitted)
#
# CHECKR_API_KEY        — secret key from Checkr dashboard (HTTP Basic user)
# CHECKR_PACKAGE        — package slug, e.g. 'tasker_pro'
# CHECKR_WEBHOOK_SECRET — HMAC secret for X-Checkr-Signature verification
# CHECKR_BASE_URL       — sandbox vs prod toggle (optional)
# CHECKR_API_KEY=
# CHECKR_PACKAGE=
# CHECKR_WEBHOOK_SECRET=
# CHECKR_BASE_URL=https://api.checkr-staging.com/v1

# Geocoder — Nominatim HTTP endpoint (S465 / Phase 1a.3).
# Defaults to the public Nominatim instance for dev; production should
# point at a dev-team-installed self-hosted Nominatim (50GB OSM data,
# ~1GB RAM). Per the in-house-everything memory: open-source libraries
# running on GAM servers count as in-house.
#
# Public instance has a usage policy limiting heavy use. Dev usage is
# fine; prod must self-host.
# GEOCODER_URL=https://nominatim.openstreetmap.org/search
